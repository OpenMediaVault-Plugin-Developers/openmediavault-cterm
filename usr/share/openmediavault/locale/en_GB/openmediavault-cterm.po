msgid "Auto-login secret"
msgstr "Auto-login secret"

msgid ""
"Auto-login secret is too short.  Must be at least 32 characters or disabled "
"with 0 characters."
msgstr ""
"Auto-login secret is too short.  Must be at least 32 characters or disabled "
"with 0 characters."

msgid "Auto-login user"
msgstr "Auto-login user"

msgid "Base path"
msgstr "Base path"

msgid "Base path to use. Leave blank to disable."
msgstr "Base path to use. Leave blank to disable."

msgid "CTerm"
msgstr "CTerm"

msgid "Date & Time"
msgstr "Date & Time"

msgid "Enable"
msgstr "Enable"

msgid "Enable host shell option in container list."
msgstr "Enable host shell option in container list."

msgid "Host"
msgstr "Host"

msgid "Host shell"
msgstr "Host shell"

msgid "IP to listen on. Use 0.0.0.0 for all IPs."
msgstr "IP to listen on. Use 0.0.0.0 for all IPs."

msgid ""
"Leave blank to disable auto-login.<br/>Should be between 32 and 64 "
"characters.<br/>Enter 'random' to generate a random string between 32 and 64"
" chars.<br/>Enter 'random64' where the number 64 can be the length between "
"32 and 64."
msgstr ""
"Leave blank to disable auto-login.<br/>Should be between 32 and 64 "
"characters.<br/>Enter 'random' to generate a random string between 32 and 64"
" chars.<br/>Enter 'random64' where the number 64 can be the length between "
"32 and 64."

msgid "Level"
msgstr "Level"

msgid "Message"
msgstr "Message"

msgid "Module"
msgstr "Module"

msgid "Open UI"
msgstr "Open UI"

msgid ""
"Override auto-login user for admins.<br/>Leave blank to use web interface "
"user.<br/>Non-admins will always use web interface user."
msgstr ""
"Override auto-login user for admins.<br/>Leave blank to use web interface "
"user.<br/>Non-admins will always use web interface user."

msgid "Port"
msgstr "Port"

msgid "Port to listen on."
msgstr "Port to listen on."

msgid "Select a user ..."
msgstr "Select a user ..."

msgid "Updated cterm settings."
msgstr "Updated cterm settings."

msgid "User must be in cterm group to login."
msgstr "User must be in cterm group to login."
